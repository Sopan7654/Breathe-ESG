# ============================================================
# breathe-esg-frontend/.env.example
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it contains secrets.
# ============================================================

# URL of the Django backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Default company ID sent as X-Company-Id header
VITE_COMPANY_ID=11111111-1111-1111-1111-111111111111

# Default analyst name sent as X-Analyst-Name header
VITE_ANALYST_NAME=Your Name
