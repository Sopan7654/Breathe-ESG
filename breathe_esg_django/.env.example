# ============================================================
# breathe_esg_django/.env.example
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it contains secrets.
# ============================================================

# Django secret key — generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to True only for local development
DEBUG=True

# Comma-separated allowed hosts (e.g., localhost,127.0.0.1,yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection URL
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# For Neon: postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/breathe_esg

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Directory where uploaded files are stored (relative to project root)
UPLOADS_DIR=uploads
